# Copy this file to .env and fill in values for your local environment.
# Never commit .env to version control.

# Directory containing Synthea-generated CSV files.
# Place patients.csv, encounters.csv, etc. here.
SYNTHEA_DATA_DIR=data/raw

# Path to the DuckDB database file (created automatically on first run).
DB_PATH=data/evidence_studio.duckdb

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
